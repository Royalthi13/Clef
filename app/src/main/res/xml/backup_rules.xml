<?xml version="1.0" encoding="utf-8"?>
<!--
    Reglas de backup de Android.
    Se excluyen todos los datos sensibles para que Android Backup
    no los suba a Google Drive sin el conocimiento del usuario.

    FIX: Añadidos patrones para los nuevos ficheros con UID (vault_*.enc,
    clef_key_cache_*.xml, clef_biometric_prefs.xml, carpeta profile/).
    El vault antiguo "vault.enc" también se mantiene excluido por compatibilidad.
-->
<full-backup-content>

    <!-- Vault cifrado — nombre legacy y nuevo formato por UID -->
    <exclude domain="file" path="vault.enc" />
    <!-- Android no soporta wildcards en backup_rules, así que excluimos
         el directorio filesDir completo de ficheros sensibles por patrón -->
    <exclude domain="file" path="." />

    <!-- Claves criptográficas cacheadas por UID -->
    <exclude domain="sharedpref" path="." />

    <!-- Fotos de perfil -->
    <exclude domain="file" path="profile" />

</full-backup-content>