<?xml version="1.0" encoding="utf-8"?>
<!--
    Reglas de backup de Android.
    Se excluyen todos los datos sensibles para que Android Backup
    no los suba a Google Drive sin el conocimiento del usuario.
-->
<full-backup-content>

    <!-- Claves criptográficas cacheadas (salt, cajaA, cajaB) -->
    <exclude domain="sharedpref" path="clef_key_cache.xml" />

    <!-- DEK cifrada con la clave biométrica del Keystore -->
    <exclude domain="sharedpref" path="clef_biometric_prefs.xml" />

    <!-- Bóveda cifrada en disco -->
    <exclude domain="file" path="vault.enc" />

    <!-- Foto de perfil local (datos personales) -->
    <exclude domain="file" path="profile_photo.jpg" />

    <!-- Preferencias generales de la app (tema, auto-lock, sync) -->
    <!-- Se excluyen porque contienen configuración sensible de seguridad -->
    <exclude domain="sharedpref" path="settings.xml" />

</full-backup-content>