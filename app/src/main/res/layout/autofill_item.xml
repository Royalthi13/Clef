        <TextView android:id="@+id/autofillTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FF0F172A" android:textSize="14sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end"/>
