<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/clef_background"
    tools:context=".ui.settings.SettingsFragment">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/topAppBar"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            app:title="@string/nav_settings"
            app:titleCentered="false"
            app:menu="@menu/settings_top_menu" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:paddingBottom="24dp">

            <!-- COLUMNA IZQUIERDA: perfil + estadísticas + cuenta -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="6dp">

                <!-- Estadísticas -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/rowStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="?attr/colorPrimaryContainer"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_info_24"
                            app:tint="?attr/colorPrimary"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:text="Estadísticas de la bóveda"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorPrimary" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_chevron_right_24"
                            app:tint="?attr/colorPrimary"
                            android:contentDescription="@null" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Perfil -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:paddingStart="8dp"
                    android:text="Perfil"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:textColor="@color/clef_primary" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardProfile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/clef_card_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/clef_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:gravity="center_vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:cardCornerRadius="24dp"
                            app:cardBackgroundColor="?attr/colorPrimaryContainer"
                            app:strokeWidth="0dp">

                            <ImageView
                                android:id="@+id/ivAvatar"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_person_24"
                                android:scaleType="centerCrop"
                                android:contentDescription="@string/profile_photo_desc" />

                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvUserName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:textColor="@color/clef_on_surface"
                                tools:text="Adrián" />

                            <TextView
                                android:id="@+id/tvUserEmail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                tools:text="adri@gmail.com" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right_24"
                            app:tint="?attr/colorOnSurfaceVariant"
                            android:contentDescription="@null" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Cuenta -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:paddingStart="8dp"
                    android:text="Cuenta"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:textColor="@color/clef_primary" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/clef_card_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/clef_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/rowHelp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                app:cardCornerRadius="10dp"
                                app:cardBackgroundColor="?attr/colorPrimaryContainer"
                                app:strokeWidth="0dp">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:padding="7dp"
                                    android:src="@drawable/ic_help_24"
                                    app:tint="?attr/colorPrimary"
                                    android:contentDescription="@null" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="10dp"
                                android:text="@string/settings_help"
                                android:textSize="14sp"
                                android:textColor="@color/clef_on_surface"
                                android:textStyle="bold" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_chevron_right_24"
                                app:tint="?attr/colorOnSurfaceVariant"
                                android:contentDescription="@null" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/clef_border" />

                        <LinearLayout
                            android:id="@+id/btnSignOut"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                app:cardCornerRadius="10dp"
                                app:cardBackgroundColor="#33FF4D4D"
                                app:strokeWidth="0dp">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:padding="7dp"
                                    android:src="@drawable/ic_logout_24"
                                    app:tint="#FFEF4444"
                                    android:contentDescription="@null" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="10dp"
                                android:text="@string/settings_sign_out"
                                android:textSize="14sp"
                                android:textColor="#FFEF4444"
                                android:textStyle="bold" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_chevron_right_24"
                                app:tint="#FFEF4444"
                                android:contentDescription="@null" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Notificaciones -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="6dp"
                    android:paddingStart="8dp"
                    android:text="Notificaciones"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:textColor="@color/clef_primary" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/clef_card_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/clef_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                app:cardCornerRadius="10dp"
                                app:cardBackgroundColor="?attr/colorPrimaryContainer"
                                app:strokeWidth="0dp">
                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:padding="7dp"
                                    android:src="@drawable/ic_info_24"
                                    app:tint="?attr/colorPrimary"
                                    android:contentDescription="@null" />
                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="10dp"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Indicadores de vigencia"
                                    android:textSize="14sp"
                                    android:textColor="@color/clef_on_surface"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Colorea las tarjetas según su estado"
                                    android:textSize="11sp"
                                    android:textColor="?attr/colorOnSurfaceVariant" />
                            </LinearLayout>

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switchColors"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/clef_border" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                app:cardCornerRadius="10dp"
                                app:cardBackgroundColor="?attr/colorPrimaryContainer"
                                app:strokeWidth="0dp">
                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:padding="7dp"
                                    android:src="@drawable/ic_notifications_24"
                                    app:tint="?attr/colorPrimary"
                                    android:contentDescription="@null" />
                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="10dp"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Avisos de caducidad"
                                    android:textSize="14sp"
                                    android:textColor="@color/clef_on_surface"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Notificación cuando una contraseña caduca"
                                    android:textSize="11sp"
                                    android:textColor="?attr/colorOnSurfaceVariant" />
                            </LinearLayout>

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switchNotifications"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/clef_border" />

                        <LinearLayout
                            android:id="@+id/rowExpiryPeriod"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                app:cardCornerRadius="10dp"
                                app:cardBackgroundColor="?attr/colorPrimaryContainer"
                                app:strokeWidth="0dp">
                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:padding="7dp"
                                    android:src="@drawable/ic_timer_24"
                                    app:tint="?attr/colorPrimary"
                                    android:contentDescription="@null" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="10dp"
                                android:text="Plazo de caducidad"
                                android:textSize="14sp"
                                android:textColor="@color/clef_on_surface"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvExpiryPeriodValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1 año"
                                android:textSize="12sp"
                                android:textColor="?attr/colorOnSurfaceVariant" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginStart="4dp"
                                android:src="@drawable/ic_chevron_right_24"
                                app:tint="?attr/colorOnSurfaceVariant"
                                android:contentDescription="@null" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="@string/settings_version"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

            <!-- COLUMNA DERECHA: seguridad + preferencias + notificaciones -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="6dp">

                <!-- Seguridad -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:paddingStart="8dp"
                    android:text="@string/settings_security"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:textColor="@color/clef_primary" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/clef_card_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/clef_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                app:cardCornerRadius="10dp"
                                app:cardBackgroundColor="?attr/colorPrimaryContainer"
                                app:strokeWidth="0dp">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:padding="7dp"
                                    android:src="@drawable/ic_fingerprint_24"
                                    app:tint="?attr/colorPrimary"
                                    android:contentDescription="@null" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="10dp"
                                android:text="@string/settings_biometrics"
                                android:textSize="14sp"
                                android:textColor="@color/clef_on_surface"
                                android:textStyle="bold" />

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switchBiometrics"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/clef_border" />

                        <LinearLayout
                            android:id="@+id/rowAutoLock"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                app:cardCornerRadius="10dp"
                                app:cardBackgroundColor="?attr/colorPrimaryContainer"
                                app:strokeWidth="0dp">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:padding="7dp"
                                    android:src="@drawable/ic_timer_24"
                                    app:tint="?attr/colorPrimary"
                                    android:contentDescription="@null" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="10dp"
                                android:text="@string/settings_auto_lock"
                                android:textSize="14sp"
                                android:textColor="@color/clef_on_surface"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvAutoLockValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="60 s"
                                android:textSize="12sp"
                                android:textColor="?attr/colorOnSurfaceVariant" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginStart="4dp"
                                android:src="@drawable/ic_chevron_right_24"
                                app:tint="?attr/colorOnSurfaceVariant"
                                android:contentDescription="@null" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/clef_border" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                app:cardCornerRadius="10dp"
                                app:cardBackgroundColor="?attr/colorPrimaryContainer"
                                app:strokeWidth="0dp">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:padding="7dp"
                                    android:src="@drawable/ic_database_24"
                                    app:tint="?attr/colorPrimary"
                                    android:contentDescription="@null" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="10dp"
                                android:text="@string/settings_sync"
                                android:textSize="14sp"
                                android:textColor="@color/clef_on_surface"
                                android:textStyle="bold" />

                            <ImageButton
                                android:id="@+id/btnSyncInfo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="6dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@drawable/ic_info_24"
                                android:padding="4dp"
                                app:tint="?attr/colorOnSurfaceVariant"
                                android:contentDescription="@null" />

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switchSync"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Preferencias -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:paddingStart="8dp"
                    android:text="@string/settings_preferences"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:textColor="@color/clef_primary" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/clef_card_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/clef_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                app:cardCornerRadius="10dp"
                                app:cardBackgroundColor="?attr/colorPrimaryContainer"
                                app:strokeWidth="0dp">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:padding="7dp"
                                    android:src="@drawable/ic_dark_mode_24"
                                    app:tint="?attr/colorPrimary"
                                    android:contentDescription="@null" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="10dp"
                                android:text="@string/settings_theme"
                                android:textSize="14sp"
                                android:textColor="@color/clef_on_surface"
                                android:textStyle="bold" />

                            <com.google.android.material.button.MaterialButtonToggleGroup
                                android:id="@+id/toggleTheme"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:saveEnabled="false"
                                app:singleSelection="true"
                                app:selectionRequired="false">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnThemeLight"
                                    style="@style/Widget.Material3.Button.OutlinedButton"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:saveEnabled="false"
                                    android:text="@string/theme_light" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnThemeDark"
                                    style="@style/Widget.Material3.Button.OutlinedButton"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:saveEnabled="false"
                                    android:text="@string/theme_dark" />

                            </com.google.android.material.button.MaterialButtonToggleGroup>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/clef_border" />

                        <LinearLayout
                            android:id="@+id/rowImportExport"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                app:cardCornerRadius="10dp"
                                app:cardBackgroundColor="?attr/colorPrimaryContainer"
                                app:strokeWidth="0dp">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:padding="7dp"
                                    android:src="@drawable/ic_database_24"
                                    app:tint="?attr/colorPrimary"
                                    android:contentDescription="@null" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="10dp"
                                android:text="@string/settings_import_export"
                                android:textSize="14sp"
                                android:textColor="@color/clef_on_surface"
                                android:textStyle="bold" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_chevron_right_24"
                                app:tint="?attr/colorOnSurfaceVariant"
                                android:contentDescription="@null" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>


            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
